# =============================================
# URL Rewriting - Iran War 2026
# =============================================

RewriteEngine On
RewriteBase /

# =============================================
# FrontOffice
# =============================================

# Page d'accueil → front/index.php
RewriteRule ^$ front/index.php [L]

# /article/mon-slug → front/article.php?slug=mon-slug
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^article/([a-z0-9\-]+)/?$ front/article.php?slug=$1 [L,QSA]

# /categorie/mon-slug → front/categorie.php?slug=mon-slug
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^categorie/([a-z0-9\-]+)/?$ front/categorie.php?slug=$1 [L,QSA]

# =============================================
# BackOffice
# =============================================

# /back → back/index.php (dashboard)
RewriteRule ^back/?$ back/index.php [L]

# /back/login → back/login.php
RewriteRule ^back/login/?$ back/login.php [L]

# /back/logout → back/logout.php
RewriteRule ^back/logout/?$ back/logout.php [L]

# /back/edit → back/edit.php
RewriteRule ^back/edit/?$ back/edit.php [L,QSA]

# /back/save → back/save.php
RewriteRule ^back/save/?$ back/save.php [L]

# /back/delete → back/delete.php
RewriteRule ^back/delete/?$ back/delete.php [L,QSA]

# =============================================
# Securite
# =============================================

# Bloquer l'acces aux fichiers sensibles
<FilesMatch "\.(sql|log|ini|env)$">
    Require all denied
</FilesMatch>

# Bloquer l'acces au dossier config
RewriteRule ^config/ - [F,L]

# Bloquer l'acces au dossier includes
RewriteRule ^includes/ - [F,L]

# =============================================
# Performance
# =============================================

# Compression Gzip
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript
</IfModule>

# Cache navigateur
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType text/css "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
</IfModule>
